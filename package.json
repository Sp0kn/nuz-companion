{
  "name": "nuz-companion",
  "version": "0.1.0",
  "description": "Pokemon Nuzlocke companion app for Twitch streaming",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -n BACK,APP -c magenta,cyan \"npm run backend:dev\" \"electron-vite dev\"",
    "backend:dev": "backend\\.venv\\Scripts\\uvicorn main:app --reload --port 8000 --app-dir backend",
    "build": "electron-vite build",
    "build:backend": "cd backend && .venv\\Scripts\\pyinstaller nuz_companion.spec --distpath dist --workpath build --noconfirm",
    "package": "npm run build:backend && electron-vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.95.2",
    "pokemon": "^3.3.0",
    "react-router-dom": "^7.13.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.2",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.nuz.companion",
    "productName": "Nuz Companion",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "backend/dist/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
